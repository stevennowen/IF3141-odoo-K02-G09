<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="survey_fill" name="Terminal Coffee Survey Form">
        <html>
            <head>
                <title>Terminal Coffee E-Survey</title>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    :root {
                        color-scheme: light;
                        font-family: Arial, sans-serif;
                        --ink: #1d2327;
                        --muted: #667085;
                        --line: #d0d5dd;
                        --brand: #246b5b;
                        --brand-dark: #17483e;
                        --bg: #f5f7f6;
                        --danger: #b42318;
                    }
                    body {
                        margin: 0;
                        background: var(--bg);
                        color: var(--ink);
                    }
                    .survey-shell {
                        max-width: 720px;
                        margin: 0 auto;
                        padding: 24px 16px 40px;
                    }
                    .survey-header {
                        padding: 8px 0 20px;
                    }
                    .survey-brand {
                        color: var(--brand);
                        font-size: 14px;
                        font-weight: 700;
                        letter-spacing: .04em;
                        text-transform: uppercase;
                    }
                    h1 {
                        margin: 8px 0 8px;
                        font-size: clamp(26px, 6vw, 38px);
                        line-height: 1.1;
                    }
                    .subtitle {
                        margin: 0;
                        color: var(--muted);
                        font-size: 16px;
                        line-height: 1.5;
                    }
                    .survey-form {
                        background: #fff;
                        border: 1px solid var(--line);
                        border-radius: 8px;
                        padding: 20px;
                        box-shadow: 0 12px 28px rgba(16, 24, 40, .08);
                    }
                    .field {
                        margin-bottom: 18px;
                    }
                    label,
                    .field-title {
                        display: block;
                        margin-bottom: 8px;
                        font-weight: 700;
                    }
                    input[type="text"],
                    input[type="tel"],
                    select,
                    textarea {
                        width: 100%;
                        box-sizing: border-box;
                        border: 1px solid var(--line);
                        border-radius: 6px;
                        padding: 12px 14px;
                        font: inherit;
                    }
                    textarea {
                        min-height: 108px;
                        resize: vertical;
                    }
                    .scale {
                        display: grid;
                        grid-template-columns: repeat(5, minmax(44px, 1fr));
                        gap: 8px;
                    }
                    .scale label {
                        border: 1px solid var(--line);
                        border-radius: 6px;
                        padding: 12px 8px;
                        text-align: center;
                        cursor: pointer;
                        font-weight: 700;
                    }
                    .scale input {
                        margin-right: 5px;
                    }
                    .error {
                        color: var(--danger);
                        font-size: 13px;
                        margin-top: 6px;
                    }
                    .submit {
                        width: 100%;
                        border: 0;
                        border-radius: 6px;
                        background: var(--brand);
                        color: #fff;
                        font: inherit;
                        font-weight: 700;
                        padding: 14px 18px;
                        cursor: pointer;
                    }
                    .submit:hover {
                        background: var(--brand-dark);
                    }
                    .required {
                        color: var(--danger);
                    }
                    @media (max-width: 520px) {
                        .survey-form {
                            padding: 16px;
                        }
                        .scale {
                            grid-template-columns: repeat(5, 1fr);
                            gap: 6px;
                        }
                        .scale label {
                            padding: 10px 4px;
                        }
                    }
                </style>
            </head>
            <body>
                <main class="survey-shell">
                    <header class="survey-header">
                        <div class="survey-brand">Terminal Coffee</div>
                        <h1><t t-esc="survey_form.name"/></h1>
                        <p class="subtitle">Bagikan pengalaman kunjungan Anda agar kami bisa meningkatkan fasilitas dan layanan.</p>
                    </header>

                    <form class="survey-form" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="field">
                            <label for="customer_name">Nama <span class="required">*</span></label>
                            <input id="customer_name" name="customer_name" type="text" t-att-value="values.get('customer_name', '')" required="required"/>
                            <div class="error" t-if="errors.get('customer_name')" t-esc="errors.get('customer_name')"/>
                        </div>

                        <div class="field">
                            <label for="segment_id">Segmen <span class="required">*</span></label>
                            <select id="segment_id" name="segment_id" required="required">
                                <option value="">Pilih segmen</option>
                                <t t-foreach="segments" t-as="segment">
                                    <option t-att-value="segment.id" t-att-selected="'selected' if values.get('segment_id') == str(segment.id) else None">
                                        <t t-esc="segment.name"/>
                                    </option>
                                </t>
                            </select>
                            <div class="error" t-if="errors.get('segment_id')" t-esc="errors.get('segment_id')"/>
                        </div>

                        <div class="field">
                            <label for="contact_number">No WhatsApp <span class="required">*</span></label>
                            <input id="contact_number" name="contact_number" type="tel" inputmode="tel" placeholder="Contoh: 081234567890" pattern="(\+?62|0)8[0-9\s().-]{7,13}" t-att-value="values.get('contact_number', '')" required="required"/>
                            <div class="error" t-if="errors.get('contact_number')" t-esc="errors.get('contact_number')"/>
                        </div>

                        <div class="field">
                            <div class="field-title">Skor Fasilitas <span class="required">*</span></div>
                            <div class="scale">
                                <t t-foreach="[1, 2, 3, 4, 5]" t-as="score">
                                    <label>
                                        <input type="radio" name="satisfaction_score" t-att-value="score" t-att-checked="'checked' if values.get('satisfaction_score') == str(score) else None"/>
                                        <t t-esc="score"/>
                                    </label>
                                </t>
                            </div>
                            <div class="error" t-if="errors.get('satisfaction_score')" t-esc="errors.get('satisfaction_score')"/>
                        </div>

                        <t t-foreach="survey_form.question_ids" t-as="question">
                            <div class="field">
                                <div class="field-title">
                                    <t t-esc="question.question_text"/>
                                    <span class="required" t-if="question.is_required">*</span>
                                </div>
                                <t t-set="field_name" t-value="'question_%s' % question.id"/>
                                <t t-if="question.answer_type == 'scale'">
                                    <div class="scale">
                                        <t t-foreach="[1, 2, 3, 4, 5]" t-as="score">
                                            <label>
                                                <input type="radio" t-att-name="field_name" t-att-value="score" t-att-checked="'checked' if values.get(field_name) == str(score) else None"/>
                                                <t t-esc="score"/>
                                            </label>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <textarea t-att-name="field_name"><t t-esc="values.get(field_name, '')"/></textarea>
                                </t>
                                <div class="error" t-if="errors.get(field_name)" t-esc="errors.get(field_name)"/>
                            </div>
                        </t>

                        <div class="field">
                            <label for="comment">Keluhan / Saran</label>
                            <textarea id="comment" name="comment"><t t-esc="values.get('comment', '')"/></textarea>
                        </div>

                        <button class="submit" type="submit">Kirim Survey</button>
                    </form>
                </main>
            </body>
        </html>
    </template>

    <template id="survey_success" name="Terminal Coffee Survey Success">
        <html>
            <head>
                <title>Survey Tersimpan</title>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { margin: 0; font-family: Arial, sans-serif; background: #f5f7f6; color: #1d2327; }
                    main { max-width: 620px; margin: 0 auto; padding: 48px 18px; }
                    section { background: #fff; border: 1px solid #d0d5dd; border-radius: 8px; padding: 28px; box-shadow: 0 12px 28px rgba(16, 24, 40, .08); }
                    h1 { margin: 0 0 10px; font-size: 30px; }
                    p { margin: 0; color: #667085; line-height: 1.5; }
                </style>
            </head>
            <body>
                <main>
                    <section>
                        <h1>Terima kasih</h1>
                        <p>Terima kasih, data Anda berhasil disimpan.</p>
                    </section>
                </main>
            </body>
        </html>
    </template>

    <template id="survey_unavailable" name="Terminal Coffee Survey Unavailable">
        <html>
            <head>
                <title>Survey Tidak Tersedia</title>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { margin: 0; font-family: Arial, sans-serif; background: #f5f7f6; color: #1d2327; }
                    main { max-width: 620px; margin: 0 auto; padding: 48px 18px; }
                    section { background: #fff; border: 1px solid #d0d5dd; border-radius: 8px; padding: 28px; }
                    h1 { margin: 0 0 10px; font-size: 30px; }
                    p { margin: 0; color: #667085; line-height: 1.5; }
                </style>
            </head>
            <body>
                <main>
                    <section>
                        <h1>Survey tidak tersedia</h1>
                        <p t-esc="message"/>
                    </section>
                </main>
            </body>
        </html>
    </template>
</odoo>
