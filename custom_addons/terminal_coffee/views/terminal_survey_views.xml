<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_terminal_survey_form_tree" model="ir.ui.view">
        <field name="name">terminal.survey.form.tree</field>
        <field name="model">terminal.survey.form</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="is_active"/>
                <field name="create_date"/>
                <field name="feedback_count"/>
                <field name="average_satisfaction"/>
                <field name="public_url"/>
            </tree>
        </field>
    </record>

    <record id="view_terminal_survey_form_form" model="ir.ui.view">
        <field name="name">terminal.survey.form.form</field>
        <field name="model">terminal.survey.form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="is_active"/>
                            <field name="public_url" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="feedback_count" readonly="1"/>
                            <field name="average_satisfaction" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pertanyaan">
                            <field name="question_ids" widget="one2many_list">
                                <tree editable="bottom" default_order="sequence">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question_text"/>
                                    <field name="answer_type"/>
                                    <field name="is_required"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Feedback">
                            <field name="feedback_ids" readonly="1">
                                <tree>
                                    <field name="fill_date"/>
                                    <field name="customer_id"/>
                                    <field name="satisfaction_score"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_terminal_survey_feedback_tree" model="ir.ui.view">
        <field name="name">terminal.survey.feedback.tree</field>
        <field name="model">terminal.survey.feedback</field>
        <field name="arch" type="xml">
            <tree>
                <field name="fill_date"/>
                <field name="customer_id"/>
                <field name="form_id"/>
                <field name="satisfaction_score"/>
                <field name="comment"/>
            </tree>
        </field>
    </record>

    <record id="view_terminal_survey_feedback_form" model="ir.ui.view">
        <field name="name">terminal.survey.feedback.form</field>
        <field name="model">terminal.survey.feedback</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="form_id"/>
                        </group>
                        <group>
                            <field name="satisfaction_score"/>
                            <field name="fill_date"/>
                        </group>
                    </group>
                    <field name="comment"/>
                    <notebook>
                        <page string="Jawaban">
                            <field name="answer_ids">
                                <tree editable="bottom">
                                    <field name="question_id"/>
                                    <field name="answer_text"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_terminal_survey_feedback_search" model="ir.ui.view">
        <field name="name">terminal.survey.feedback.search</field>
        <field name="model">terminal.survey.feedback</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_id"/>
                <field name="form_id"/>
                <field name="fill_date"/>
                <filter name="has_complaint" string="Ada Keluhan" domain="[('comment', '!=', False)]"/>
                <separator/>
                <filter name="date_filter" string="Tanggal Isi" date="fill_date"/>
                <group expand="0" string="Group By">
                    <filter name="group_form" string="Form" context="{'group_by': 'form_id'}"/>
                    <filter name="group_date" string="Tanggal" context="{'group_by': 'fill_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_terminal_survey_feedback_graph" model="ir.ui.view">
        <field name="name">terminal.survey.feedback.graph</field>
        <field name="model">terminal.survey.feedback</field>
        <field name="arch" type="xml">
            <graph string="Rata-rata Kepuasan Pelanggan" type="line">
                <field name="fill_date" interval="day"/>
                <field name="satisfaction_score" type="measure" operator="avg"/>
            </graph>
        </field>
    </record>

    <record id="view_terminal_survey_feedback_pivot" model="ir.ui.view">
        <field name="name">terminal.survey.feedback.pivot</field>
        <field name="model">terminal.survey.feedback</field>
        <field name="arch" type="xml">
            <pivot string="Analisis Kepuasan">
                <field name="form_id" type="row"/>
                <field name="fill_date" interval="month" type="col"/>
                <field name="satisfaction_score" type="measure" operator="avg"/>
            </pivot>
        </field>
    </record>

    <record id="action_terminal_survey_form" model="ir.actions.act_window">
        <field name="name">Form Kuesioner</field>
        <field name="res_model">terminal.survey.form</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_terminal_survey_feedback" model="ir.actions.act_window">
        <field name="name">Feedback Survei</field>
        <field name="res_model">terminal.survey.feedback</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_terminal_survey_feedback_search"/>
    </record>
</odoo>
