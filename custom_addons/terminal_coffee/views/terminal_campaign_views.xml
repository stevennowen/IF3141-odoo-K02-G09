<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_terminal_campaign_tree" model="ir.ui.view">
        <field name="name">terminal.campaign.tree</field>
        <field name="model">terminal.campaign</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="promotion_type"/>
                <field name="segment_criteria_id"/>
                <field name="loyalty_min_score"/>
                <field name="create_date"/>
                <field name="interaction_count"/>
            </tree>
        </field>
    </record>

    <record id="view_terminal_campaign_form" model="ir.ui.view">
        <field name="name">terminal.campaign.form</field>
        <field name="model">terminal.campaign</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_distribute_promotions" type="object" string="Distribusikan Promosi" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="promotion_type"/>
                            <field name="segment_criteria_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="loyalty_min_score"/>
                            <field name="create_date" readonly="1"/>
                            <field name="interaction_count" readonly="1"/>
                        </group>
                    </group>
                    <field name="message" placeholder="Isi pesan atau kode e-voucher yang akan dikirim"/>
                    <notebook>
                        <page string="Riwayat Pengiriman">
                            <field name="interaction_ids" readonly="1">
                                <tree>
                                    <field name="send_date"/>
                                    <field name="customer_id"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_terminal_interaction_tree" model="ir.ui.view">
        <field name="name">terminal.interaction.tree</field>
        <field name="model">terminal.interaction</field>
        <field name="arch" type="xml">
            <tree>
                <field name="send_date"/>
                <field name="campaign_id"/>
                <field name="customer_id"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_terminal_interaction_form" model="ir.ui.view">
        <field name="name">terminal.interaction.form</field>
        <field name="model">terminal.interaction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="campaign_id"/>
                        <field name="customer_id"/>
                        <field name="send_date"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_terminal_campaign" model="ir.actions.act_window">
        <field name="name">Kampanye Promosi</field>
        <field name="res_model">terminal.campaign</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_terminal_interaction" model="ir.actions.act_window">
        <field name="name">Riwayat Interaksi</field>
        <field name="res_model">terminal.interaction</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
